# Copy to .env and adjust for local dev.
# All vars here map 1:1 to what aps-backend reads via pydantic-settings
# (see aps-backend/app/config/config.py) plus a few docker-compose host-port knobs.

# ─── Host ports (docker-compose only) ─────────────────────────────────
APS_DB_PORT=5433
APS_API_PORT=8001
APS_FE_PORT=5173
APS_NEO4J_HTTP_PORT=7474
APS_NEO4J_BOLT_PORT=7687

# ─── Postgres (APS) ───────────────────────────────────────────────────
APS_DB_NAME=aps_db
APS_DB_USER=aps_user
APS_DB_PASSWORD=aps12345
# In-container URL uses hostname "db" (compose service). For host-side tools
# (host uv run, psql from host) override to postgresql://.../@localhost:5433/...
APS_DB_URL=postgresql://aps_user:aps12345@db:5432/aps_db

# ─── Neo4j (kept for future AI/graph platform; APS itself doesn't query it) ─
APS_NEO4J_URI=bolt://neo4j:7687
APS_NEO4J_USER=neo4j
APS_NEO4J_PASSWORD=aps-password
APS_NEO4J_DATABASE=neo4j
APS_NEO4J_SILENCE_NOTIFICATIONS=true

# ─── Runtime ──────────────────────────────────────────────────────────
API_VERSION=v1
DEBUG=False
LOG_LEVEL=INFO
APS_TIMEZONE=Asia/Seoul
APS_CALENDAR_TIMEZONE=Asia/Seoul

# ─── G-System (external ERP DB + REST API — sync source) ──────────────
GSYSTEM_BASE_URL=
GSYSTEM_API_KEY=
GSYSTEM_TIMEOUT=30
GSYSTEM_RETRIES=3
GSYSTEM_DB_URL=
GSYSTEM_DB_USER=
GSYSTEM_DB_PASSWORD=

# G-System auto sync (APScheduler inside API process). Use uvicorn --workers 1.
GSYSTEM_SYNC_CRON_ENABLED=false
# 5-field cron (minute hour day month day_of_week) — default Sunday 03:00
GSYSTEM_SYNC_CRON=0 3 * * 0
GSYSTEM_SYNC_CRON_TIMEZONE=UTC

# ─── LLM (Qwen3-8B via OpenAI-compatible API) ─────────────────────────
# think config — deep reasoning, used by RiskDetailService
LLM_LLM_CONFIGS__THINK__API_URL=http://host.docker.internal:8080/v1/chat/completions
LLM_LLM_CONFIGS__THINK__MODEL_NAME=Qwen/Qwen3-8B
LLM_LLM_CONFIGS__THINK__TEMPERATURE=0.6
LLM_LLM_CONFIGS__THINK__MAX_TOKENS=8192
LLM_LLM_CONFIGS__THINK__TIMEOUT=60
LLM_LLM_CONFIGS__THINK__STREAMING=true
LLM_LLM_CONFIGS__THINK__THINKING=true

# no_think config — fast response, used by SuggestionService
LLM_LLM_CONFIGS__NO_THINK__API_URL=http://host.docker.internal:8080/v1/chat/completions
LLM_LLM_CONFIGS__NO_THINK__MODEL_NAME=Qwen/Qwen3-8B
LLM_LLM_CONFIGS__NO_THINK__TEMPERATURE=0.7
LLM_LLM_CONFIGS__NO_THINK__MAX_TOKENS=4096
LLM_LLM_CONFIGS__NO_THINK__TIMEOUT=30
LLM_LLM_CONFIGS__NO_THINK__STREAMING=true
LLM_LLM_CONFIGS__NO_THINK__THINKING=false
