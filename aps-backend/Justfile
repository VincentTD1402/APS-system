set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]

python := "uv run python"
uvicorn := "uv run uvicorn"
alembic := "uv run alembic"
pytest := "uv run pytest"
ruff := "uv run ruff"
mypy := "uv run mypy"

# Import OS-specific recipes (auto-picked by [unix] / [windows] attributes)
import '.just/unix.just'
import '.just/windows.just'

# Default: list recipes with OS info
default:
    @echo "aps-backend · OS: {{os()}}"
    @just --list

# Install deps (uv sync — cross-platform)
install:
    uv sync

# Run dev server locally (outside Docker)
dev port="8000":
    {{uvicorn}} app.main:app --reload --host 0.0.0.0 --port {{port}}

# Run prod server locally
prod port="8000":
    {{uvicorn}} app.main:app --host 0.0.0.0 --port {{port}} --workers 2

# Apply pending migrations (chạy inside backend container)
migrate:
    docker compose exec backend {{alembic}} upgrade head

# Create new migration. Usage: just migration "add_xxx_table"
migration name:
    docker compose exec backend {{alembic}} revision --autogenerate -m "{{name}}"

# Roll back one migration step
downgrade:
    docker compose exec backend {{alembic}} downgrade -1

# Seed reference data (mock G-System import)
seed:
    docker compose exec backend {{python}} -m app.cli import-gsystem --source=mock

# Run tests
test *args:
    {{pytest}} {{args}}

# Coverage report
coverage:
    {{pytest}} --cov=app --cov-report=term-missing --cov-report=html

# Lint (ruff)
lint:
    {{ruff}} check app tests

# Type check (mypy)
typecheck:
    {{mypy}} app

# Format (ruff format + auto-fix)
fmt:
    {{ruff}} format app tests
    {{ruff}} check --fix app tests
