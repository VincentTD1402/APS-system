# Common configuration settings for the application
API_VERSION =v1
DEBUG =True
LOG_LEVEL=INFO

# GSystem configuration

## GSystem database connection settings
GSYSTEM_DB_URL=postgresql://user:password@localhost:5432/gsystem
GSYSTEM_DB_USER=user
GSYSTEM_DB_PASSWORD=password

## GSystem API settings
GSYSTEM_BASE_URL=https://gsystem-api.example.com
GSYSTEM_API_KEY=api_key
GSYSTEM_TIMEOUT=30
GSYSTEM_RETRIES=3

# G-System auto sync (APScheduler inside API process). Use uvicorn --workers 1.
GSYSTEM_SYNC_CRON_ENABLED=false
# 5 fields (APScheduler): minute hour day month day_of_week — default Sunday 03:00 UTC
GSYSTEM_SYNC_CRON=0 3 * * 0
GSYSTEM_SYNC_CRON_TIMEZONE=UTC


# APS configuration
APS_DB_URL=postgresql://user:password@localhost:5432/aps_db
# bolt://neo4j:7687 — when the API runs in Docker Compose (hostname = service name).
# bolt://localhost:7687 — when the API runs on the host; Neo4j maps port 7687 to the host.
APS_NEO4J_URI=bolt://neo4j:7687
APS_NEO4J_USER=neo4j
APS_NEO4J_PASSWORD=aps-password
APS_NEO4J_DATABASE=neo4j
APS_NEO4J_SILENCE_NOTIFICATIONS=true # true = suppress Neo4j 01N50/51/52 (schema/catalog) warnings. Set false when debugging the graph.


# LLM Configuration (Qwen3-8B via OpenAI-compatible API)
## think config — deep reasoning, used by RiskDetailService
LLM_LLM_CONFIGS__THINK__API_URL=http://host.docker.internal:8080/v1/chat/completions
LLM_LLM_CONFIGS__THINK__MODEL_NAME=Qwen/Qwen3-8B
LLM_LLM_CONFIGS__THINK__TEMPERATURE=0.6
LLM_LLM_CONFIGS__THINK__MAX_TOKENS=8192
LLM_LLM_CONFIGS__THINK__TIMEOUT=60
LLM_LLM_CONFIGS__THINK__STREAMING=true
LLM_LLM_CONFIGS__THINK__THINKING=true

## no_think config — fast response, used by SuggestionService
LLM_LLM_CONFIGS__NO_THINK__API_URL=http://host.docker.internal:8080/v1/chat/completions
LLM_LLM_CONFIGS__NO_THINK__MODEL_NAME=Qwen/Qwen3-8B
LLM_LLM_CONFIGS__NO_THINK__TEMPERATURE=0.7
LLM_LLM_CONFIGS__NO_THINK__MAX_TOKENS=4096
LLM_LLM_CONFIGS__NO_THINK__TIMEOUT=30
LLM_LLM_CONFIGS__NO_THINK__STREAMING=true
LLM_LLM_CONFIGS__NO_THINK__THINKING=false
